# IDA karar verme modülü seri port ayarları.
# En güvenlisi /dev/serial/by-id/... yollarını kullanmaktır.

IDA_TEL_PORT=/dev/ttyUSB0
IDA_MOTOR_PORT=/dev/ttyUSB1
IDA_GPS_PORT=/dev/ttyACM1
IDA_GPS_BAUD=115200
IDA_IMU_PORT=/dev/ttyACM0

# Her çalıştırmada bu dizinin altında yeni bir oturum klasörü oluşur.
# Kurulum betiği bu satırı gerçek kullanıcı ev dizinine göre otomatik değiştirir.
IDA_LOG_DIR=__IDA_HOME__/ida_logs

# Dead-reckoning ayarları
IDA_DR_MAX_FORWARD_MPS=2.0
IDA_DR_MAX_LATERAL_MPS=0.45
IDA_DR_PWM_DEADZONE=0.03

RUST_BACKTRACE=1
